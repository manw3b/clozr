# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Lock file for Rust — committed so CI gets reproducible builds
# (src-tauri/Cargo.lock is intentionally tracked)

# Environment
.env
.env.local
.env.*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Assets working folder (raw multimedia files for processing)
assets_generales/

# Test coverage
coverage/

# ─── DATOS DE USUARIO — NUNCA en el repo ─────────────────────────────
# Los datos de cada negocio (clientes, ventas, deudas, inventario) viven
# en clozr.db en el AppData del SO de cada usuario. Esos datos son del
# DUEÑO del negocio, no del repositorio de código. Clozr (la app) es
# independiente de los datos que cada usuario carga.
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
# Backups generados por la propia app (Settings → Datos y backup)
backups/
*.bak
# CSV / vCard exports que el user puede generar para llevarse su data
clientes-*.csv
ventas-*.csv
deudas-*.csv
*.vcf
