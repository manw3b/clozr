{
  "identifier": "default",
  "description": "Capacidades por defecto de la ventana principal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "whatsapp://*" },
        { "url": "https://wa.me/*" },
        { "url": "https://api.whatsapp.com/*" },
        { "url": "https://web.whatsapp.com/*" },
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-remove",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:scope-home-recursive",
    "fs:scope-appdata-recursive",
    "dialog:allow-open",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart"
  ]
}
